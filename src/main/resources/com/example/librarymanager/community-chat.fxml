<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="556.0" prefWidth="936.0" styleClass="pane_one1" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.librarymanager.ChatController">
    <children>
        <Pane layoutX="14.0" layoutY="14.0" prefHeight="70.0" prefWidth="908.0" styleClass="head" stylesheets="@style.css">
            <children>
                <Label layoutX="14.0" layoutY="11.0" text="Community Chat" textFill="#913434">
                    <font>
                        <Font name="Algerian" size="43.0" />
                    </font>
                </Label>
                <Button layoutX="800.0" layoutY="20.0" mnemonicParsing="false" onAction="#onBackButtonClick" prefHeight="30.0" prefWidth="80.0" text="Back" />
            </children>
        </Pane>

        <TextArea fx:id="chatArea" editable="false" layoutX="14.0" layoutY="100.0" prefHeight="380.0" prefWidth="908.0" styleClass="text-area" wrapText="true">
            <font>
                <Font name="Century Gothic" size="14.0" />
            </font>
        </TextArea>

        <HBox layoutX="14.0" layoutY="495.0" prefHeight="40.0" prefWidth="908.0" spacing="10.0">
            <children>
                <TextField fx:id="messageField" onAction="#handleSendMessage" prefHeight="40.0" prefWidth="800.0" promptText="Type your message here..." styleClass="txt_search" />
                <Button mnemonicParsing="false" onAction="#handleSendMessage" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: #913434;" text="Send" textFill="WHITE">
                    <font>
                        <Font name="Century Gothic Bold" size="14.0" />
                    </font>
                </Button>
            </children>
        </HBox>
    </children>
</AnchorPane>