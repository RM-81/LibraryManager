<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="556.0" prefWidth="936.0" styleClass="pane_one1" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.librarymanager.ChatController">
    <children>
        <Pane layoutX="14.0" layoutY="14.0" prefHeight="70.0" prefWidth="908.0" styleClass="head" stylesheets="@style.css">
            <children>
                <Label layoutX="14.0" layoutY="11.0" text="Community Chat" textFill="#00524d">
                    <font>
                        <Font name="Algerian" size="43.0" />
                    </font>
                </Label>
                <Button layoutX="800.0" layoutY="20.0" mnemonicParsing="false" onAction="#onBackButtonClick" prefHeight="30.0" prefWidth="80.0" style="-fx-background-color: #48A89A;" text="Back" textFill="#cbefeb">
               <font>
                  <Font name="Algerian" size="15.0" />
               </font></Button>
            </children>
        </Pane>

        <TextArea fx:id="chatArea" editable="false" layoutX="14.0" layoutY="100.0" prefHeight="380.0" prefWidth="908.0" style="-fx-background-color: #CBEFEB;" styleClass="text-area" wrapText="true">
            <font>
                <Font name="Century Gothic" size="14.0" />
            </font>
        </TextArea>

        <HBox layoutX="14.0" layoutY="495.0" prefHeight="40.0" prefWidth="908.0" spacing="10.0">
            <children>
                <TextField fx:id="messageField" onAction="#handleSendMessage" prefHeight="40.0" prefWidth="800.0" promptText="Type your message here..." styleClass="txt_search" />
                <Button mnemonicParsing="false" onAction="#handleSendMessage" prefHeight="40.0" prefWidth="90.0" style="-fx-background-color: #48A89A;" text="Send" textFill="#cbefeb">
                    <font>
                        <Font name="Century Gothic Bold" size="14.0" />
                    </font>
                </Button>
            </children>
        </HBox>
    </children>
</AnchorPane>
